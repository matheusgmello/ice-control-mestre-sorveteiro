

# --- BANCO DE DATOS ---
# OPÇÃO A: Se estiver usando o Docker (docker-compose.yml)
DATABASE_URL=postgresql://icecontrol:icecontrol123@localhost:5432/icecontrol

# OPÇÃO B: Se estiver usando o PostgreSQL instalado diretamente no Windows (pgAdmin)
# Substitua "SUA_SENHA" pela senha que você definiu no pgAdmin
# DATABASE_URL=postgresql://postgres:SUA_SENHA@localhost:5432/icecontrol


# --- PORTAS DOS SERVIDORES ---
PORT_API=3001
PORT_WEB=3000


# --- CONFIGURAÇÕES DO SISTEMA ---
BASE_PATH=/

# Segredo JWT — troque para uma string aleatória longa em produção
JWT_SECRET=icecontrol-secret-local-2025

# Ambiente
NODE_ENV=development
