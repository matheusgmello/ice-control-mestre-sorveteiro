# ============================================================
#  IceControl v2.0 — Configurações para uso local (Windows)
#  Copie este arquivo para ".env" antes de iniciar o sistema.
#  O script "iniciar.bat" faz isso automaticamente.
# ============================================================

# Banco de dados — deve bater com o docker-compose.yml
DATABASE_URL=postgresql://icecontrol:icecontrol123@localhost:5432/icecontrol

# Portas dos servidores locais
PORT_API=3001
PORT_WEB=3000

# Caminho base da aplicação (manter "/" para uso local)
BASE_PATH=/

# Segredo JWT — troque para uma string aleatória longa em produção
JWT_SECRET=icecontrol-secret-local-2025

# Ambiente
NODE_ENV=development
